diff --git a/linux/CMakeLists.txt b/linux/CMakeLists.txt
index 0000000..0000000 100644
--- a/linux/CMakeLists.txt
+++ b/linux/CMakeLists.txt
@@ -1,6 +1,20 @@
 cmake_minimum_required(VERSION 3.13)
 project(runner LANGUAGES CXX)

+# Flatpak/Linux workaround:
+# Some transitive plugin CMake scripts (notably sentry_flutter native bits) may
+# unconditionally call find_package(JNI REQUIRED), which fails in Linux desktop
+# builds where JNI is not needed.
+#
+# Force CMake's FindJNI module to think JNI is intentionally unavailable,
+# preventing REQUIRED failures for Linux desktop targets.
+set(CMAKE_DISABLE_FIND_PACKAGE_JNI ON CACHE BOOL "Disable JNI lookup for Linux desktop builds" FORCE)
+
+# Optional compatibility vars for scripts that inspect them directly
+set(JNI_FOUND FALSE CACHE BOOL "" FORCE)
+unset(JAVA_INCLUDE_PATH CACHE)
+unset(JAVA_INCLUDE_PATH2 CACHE)
+unset(JAVA_JVM_LIBRARY CACHE)
+
 set(BINARY_NAME "plezy")
